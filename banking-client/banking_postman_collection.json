		{
			"name": "Compliance & Privacy",
			"item": [
				{
					"name": "Upload Private KYC Docs (Transient PII)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "X-Org", "value": "BankA" },
							{ "key": "X-Role", "value": "teller" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"fullName\": \"Alice Smith\",\n    \"nationalId\": \"US-987-654-321\",\n    \"documentHash\": \"f2d9a3b8d4e9c701b2a95c102bd92c102bd8a7\"\n}"
						},
						"url": {
							"raw": "http://localhost:3000/accounts/acc100/kycdoc",
							"protocol": "http",
							"host": ["localhost"],
							"port": "3000",
							"path": ["accounts", "acc100", "kycdoc"]
						}
					}
				},
				{
					"name": "Read Private KYC Doc (Private Access)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "X-Org", "value": "BankA" },
							{ "key": "X-Role", "value": "teller" }
						],
						"url": {
							"raw": "http://localhost:3000/accounts/acc100/kycdoc",
							"protocol": "http",
							"host": ["localhost"],
							"port": "3000",
							"path": ["accounts", "acc100", "kycdoc"]
						}
					}
				},
