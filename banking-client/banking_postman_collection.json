	"item": [
		{
			"name": "Account Management",
			"item": [
				{
					"name": "Create Account (Alice)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "X-Org", "value": "BankA" },
							{ "key": "X-Role", "value": "teller" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"id\": \"acc100\",\n    \"owner\": \"Alice Smith\",\n    \"balance\": 5000.00\n}"
						},
						"url": {
							"raw": "http://localhost:3000/accounts",
							"protocol": "http",
							"host": ["localhost"],
							"port": "3000",
							"path": ["accounts"]
						}
					}
				},
				{
					"name": "Get Account Details",
					"request": {
						"method": "GET",
