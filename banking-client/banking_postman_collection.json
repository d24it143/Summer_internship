					"name": "Flag Suspicious Transaction",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "X-Org", "value": "RegulatorOrg" },
							{ "key": "X-Role", "value": "compliance_officer" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"accountID\": \"acc100\"\n}"
						},
						"url": {
							"raw": "http://localhost:3000/transactions/mock_tx_id/flag",
							"protocol": "http",
							"host": ["localhost"],
							"port": "3000",
							"path": ["transactions", "mock_tx_id", "flag"]
						}
					}
				},
				{
					"name": "Get Audit Trail (Regulator Org Only)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "X-Org", "value": "RegulatorOrg" },
							{ "key": "X-Role", "value": "compliance_officer" }
						],
						"url": {
							"raw": "http://localhost:3000/audit?query={\"selector\":{\"docType\":\"transaction\"}}",
							"protocol": "http",
							"host": ["localhost"],
							"port": "3000",
							"path": ["audit"],
							"query": [
								{ "key": "query", "value": "{\"selector\":{\"docType\":\"transaction\"}}" }
							]
						}
					}
				}
			]
